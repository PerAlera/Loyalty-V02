generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  phone        String        @unique
  passwordHash String
  name         String
  surname      String
  role         Role          @default(CUSTOMER)
  birthDate    DateTime?
  gender       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  wallets      Wallet[]
  transactions Transaction[] @relation("UserTransactions")
  qrTokens     QrToken[]
  store        Store?        @relation("StoreOwner")
  storeCashier Store?        @relation("StoreCashier", fields: [storeId], references: [id])
  storeId      String?
}

enum Role {
  CUSTOMER
  OWNER
  CASHIER
}

model Store {
  id            String         @id @default(cuid())
  name          String
  ownerId       String         @unique
  owner         User           @relation("StoreOwner", fields: [ownerId], references: [id])
  cashiers      User[]         @relation("StoreCashier")
  settings      StoreSettings?
  announcements Announcement[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model StoreSettings {
  id              String   @id @default(cuid())
  storeId         String   @unique
  store           Store    @relation(fields: [storeId], references: [id])
  requiredCoffees Int      @default(10)
  requiredFoods   Int      @default(10)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Wallet {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  beans       Int      @default(0) // Çekirdek (Puan) sayısı (Kahve)
  rewards     Int      @default(0) // Kazanılan ücretsiz kahve sayısı
  foodPoints  Int      @default(0) // Yemek puanı sayısı
  foodRewards Int      @default(0) // Kazanılan ücretsiz yemek sayısı
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Transaction {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation("UserTransactions", fields: [userId], references: [id])
  type      TransactionType
  amount    Int              // Kazanılan/Harcanan miktar
  createdAt DateTime         @default(now())
}

enum TransactionType {
  EARN_BEAN       // Çekirdek (Kahve) kazanma
  SPEND_BEAN      // Kahve çekirdeğinin sıfırlanıp ödüle dönüşmesi
  REDEEM_REWARD   // Kahve ödülü kullanımı
  EARN_FOOD       // Yemek puanı kazanma
  SPEND_FOOD      // Yemek puanının sıfırlanıp ödüle dönüşmesi
  REDEEM_FOOD     // Yemek ödülü kullanımı
}

model QrToken {
  id          String       @id @default(cuid())
  token       String       @unique
  userId      String?
  user        User?        @relation(fields: [userId], references: [id])
  type        QrType
  productType ProductType  @default(COFFEE)
  beans       Int?         // Kazanılacak puan adedi (Kahve veya Yemek)
  expiresAt   DateTime
  isUsed      Boolean      @default(false)
  createdAt   DateTime     @default(now())
}

enum QrType {
  EARN      // Kasiyerin oluşturduğu, müşterinin okuttuğu (Puan Kazanma)
  REDEEM    // Müşterinin oluşturduğu, kasiyerin okuttuğu (Ödül Kullanma)
}

enum ProductType {
  COFFEE
  FOOD
}
